      }
    },
    {
      "object": "block",
      "type": "bulleted_list_item",
      "bulleted_list_item": {
        "rich_text": [{"text": {"content": "子类型证明：subtype_mk 需要同时提供元素和 membership 证明"}}]
      }
    },
    {
      "object": "block",
      "type": "bulleted_list_item",
      "bulleted_list_item": {
        "rich_text": [{"text": {"content": "ext 策略：使用 extensionality 证明集合相等，需要证明双向包含"}}]
      }
    },
