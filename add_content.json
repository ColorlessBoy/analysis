    {
      "object": "block",
      "type": "heading_2",
      "heading_2": {
        "rich_text": [{"text": {"content": "核心知识点"}}]
      }
    },
    {
      "object": "block",
      "type": "bulleted_list_item",
      "bulleted_list_item": {
        "rich_text": [{"text": {"content": "函数定义 Function X Y：通过 P : X → Y → Prop 和唯一性条件 unique 定义"}}]
      }
    },
    {
      "object": "block",
      "type": "bulleted_list_item",
      "bulleted_list_item": {
        "rich_text": [{"text": {"content": "函数相等：f = g ↔ ∀x, f x = g x (Function.eq_iff)"}}]
      }
    },
    {
      "object": "block",
      "type": "bulleted_list_item",
      "bulleted_list_item": {
        "rich_text": [{"text": {"content": "复合函数 g ○ f：通过 mk_fn 和 to_fn 进行类型转换"}}]
      }
    },
    {
      "object": "block",
      "type": "bulleted_list_item",
      "bulleted_list_item": {
        "rich_text": [{"text": {"content": "单射 one_to_one：∀x x', x ≠ x' → f x ≠ f x'"}}]
      }
    },
    {
      "object": "block",
      "type": "bulleted_list_item",
      "bulleted_list_item": {
        "rich_text": [{"text": {"content": "满射 onto：∀y, ∃x, f x = y"}}]
      }
    },
    {
      "object": "block",
      "type": "bulleted_list_item",
      "bulleted_list_item": {
        "rich_text": [{"text": {"content": "双射 bijective：单射 ∧ 满射"}}]
      }
    },
    {
      "object": "block",
      "type": "bulleted_list_item",
      "bulleted_list_item": {
        "rich_text": [{"text": {"content": "逆函数 inverse：仅对双射函数定义"}}]
      }
    },
    {
      "object": "block",
      "type": "bulleted_list_item",
      "bulleted_list_item": {
        "rich_text": [{"text": {"content": "包含函数 inclusion：从子集到父集的嵌入函数"}}]
      }
    },
    {
      "object": "block",
      "type": "heading_2",
      "heading_2": {
        "rich_text": [{"text": {"content": "难点"}}]
      }
    },
