{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "lean-lsp": {
      "type": "local",
      "command": ["uvx", "lean-lsp-mcp"],
      "enabled": true,
      "timeout": 120000
    }
  },
  "lsp": true,
  "permission": {
    "*": "allow",
    "read": "allow",
    "edit": "allow",
    "write": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": "allow",
    "task": "allow",
    "webfetch": "allow",
    "skill": "allow",
    "question": "allow",
    "todowrite": "allow",
    "todoread": "allow"
  }
}
