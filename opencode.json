{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/deepseek-v4-flash",
  "provider": {
    "opencode-go": {
      "models": {
        "deepseek-v4-flash": {
          "variants": {
            "max": {
              "reasoningEffort": "max",
              "textVerbosity": "low"
            }
          }
        }
      }
    }
  },
  "mcp": {
    "lean-lsp": {
      "type": "local",
      "command": ["uvx", "lean-lsp-mcp", "--lean-project-path", "/Users/bilibili/Documents/lean/analysis"],
      "enabled": true,
      "timeout": 120000
    }
  },
  "lsp": true,
  "permission": {
    "*": "allow",
    "read": "allow",
    "edit": "allow",
    "write": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": "allow",
    "task": "allow",
    "webfetch": "allow",
    "skill": "allow",
    "question": "allow",
    "todowrite": "allow",
    "todoread": "allow"
  }
}
