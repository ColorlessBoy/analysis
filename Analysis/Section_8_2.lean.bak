import Mathlib.Tactic
import Analysis.Section_7_2
import Analysis.Section_7_3
import Analysis.Section_7_4
import Analysis.Section_8_1

/-!
# Analysis I, Section 8.2: Summation on infinite sets

I have attempted to make the translation as faithful a paraphrasing as possible of the original
text. When there is a choice between a more idiomatic Lean solution and a more faithful
translation, I have generally chosen the latter. In particular, there will be places where the
Lean code could be "golfed" to be more elegant and idiomatic, but I have consciously avoided
doing so.

Main constructions and results of this section:

- Absolute convergence and summation on countably infinite or general sets.
- Connections with Mathlib's {name}`Summable` and {name}`tsum`.
- The Riemann rearrangement theorem.

Some non-trivial API is provided beyond what is given in the textbook in order connect these
notions with existing summation notions.

After this section, the summation notation developed here will be deprecated in favor of Mathlib's API for {name}`Summable` and {name}`tsum`.

-/

namespace Chapter8
open Chapter7 Chapter7.Series Finset Function Filter

/-- Definition 8.2.1 (Series on countable sets).  Note that with this definition, functions defined
on finite sets will not be absolutely convergent; one should use {lit}`AbsConvergent'` instead for such
cases.-/
abbrev AbsConvergent {X:Type} (f: X → ℝ) : Prop := ∃ g: ℕ → X, Bijective g ∧ (f ∘ g: Series).absConverges

theorem AbsConvergent.mk {X: Type} {f:X → ℝ} {g:ℕ → X} (h: Bijective g) (hfg: (f ∘ g:Series).absConverges) : AbsConvergent f := by use g

open Classical in
/-- The definition has been chosen to give a sensible value when {name}`X` is finite, even though
{name}`AbsConvergent` is by definition false in this context. -/
noncomputable abbrev Sum {X:Type} (f: X → ℝ) : ℝ := if h: AbsConvergent f then (f ∘ h.choose:Series).sum else
  if _hX: Finite X then (∑ x ∈ @univ X (Fintype.ofFinite X), f x) else 0

theorem Sum.of_finite {X:Type} [hX:Finite X] (f:X → ℝ) : Sum f = ∑ x ∈ @Finset.univ X (Fintype.ofFinite X), f x := by
  have : ¬ AbsConvergent f := by
    by_contra!; choose g hg _ using this
    rw [←hg.finite_iff, ←not_infinite_iff_finite] at hX; apply hX; infer_instance
  simp [Sum, this, hX]

theorem AbsConvergent.comp {X: Type} {f:X → ℝ} {g:ℕ → X} (h: Bijective g) (hf: AbsConvergent f) : (f ∘ g:Series).absConverges := by
  choose g' hbij hconv using hf
  choose g'_inv hleft hright using bijective_iff_has_inverse.mp hbij
  have hG : Bijective (g'_inv ∘ g) := .comp ⟨hright.injective, hleft.surjective⟩ h
  convert (absConverges_of_permute hconv hG).1 using 4 with n
  simp [hright (g n.toNat)]

theorem Sum.eq {X: Type} {f:X → ℝ} {g:ℕ → X} (h: Bijective g) (hfg: (f ∘ g:Series).absConverges) : (f ∘ g:Series).convergesTo (Sum f) := by
  have : AbsConvergent f := .mk h hfg
  simp [Sum, this]
  choose hbij hconv using this.choose_spec
  set g' := this.choose
  choose g'_inv hleft hright using bijective_iff_has_inverse.mp hbij
  convert convergesTo_sum (converges_of_absConverges hfg) using 1
  have hG : Bijective (g'_inv ∘ g) := .comp ⟨hright.injective, hleft.surjective⟩ h
  convert (absConverges_of_permute hconv hG).2 using 4 with _ n
  by_cases hn : n ≥ 0 <;> simp [hn, hright (g n.toNat)]

theorem Sum.of_comp {X Y:Type} {f:X → ℝ} (h: AbsConvergent f) {g: Y → X} (hbij: Bijective g) : AbsConvergent (f ∘ g) ∧ Sum f = Sum (f ∘ g) := by
  choose g' hbij' hconv' using h
  choose g_inv hleft hright using bijective_iff_has_inverse.mp hbij
  have hbij_g_inv_g' : Bijective (g_inv ∘ g') := .comp ⟨hright.injective, hleft.surjective⟩ hbij'
  have hident : (f ∘ g) ∘ g_inv ∘ g' = f ∘ g' := by ext n; simp [hright (g' n)]
  refine ⟨ ⟨ g_inv ∘ g', ⟨ hbij_g_inv_g', by convert hconv' ⟩ ⟩, ?_ ⟩
  have h := eq (f := f ∘ g) hbij_g_inv_g' (by convert hconv')
  rw [hident] at h
  solve_by_elim [convergesTo_uniq, eq]

@[simp]
theorem Finset.Icc_eq_cast (N:ℕ) : Icc 0 (N:ℤ) = map Nat.castEmbedding (.Icc 0 N) := by
  ext n; simp; constructor
  . intro ⟨ hn, _ ⟩; lift n to ℕ using hn; use n; simp_all
  rintro ⟨ _, ⟨ _, rfl ⟩ ⟩; simp_all

theorem Finset.Icc_empty {N:ℤ} (h: ¬ N ≥ 0) : Icc 0 N = ∅ := by
  ext; simp; intros; contrapose! h; linarith

/-- Theorem 8.2.2, preliminary version.  The arguments here are rearranged slightly from the text. -/
theorem sum_of_sum_of_AbsConvergent_nonneg {f:ℕ × ℕ → ℝ} (hf:AbsConvergent f) (hpos: ∀ n m, 0 ≤ f (n, m)) :
  (∀ n, ((fun m ↦ f (n, m)):Series).converges) ∧
  (fun n ↦ ((fun m ↦ f (n, m)):Series).sum:Series).convergesTo (Sum f) := by
  set L := Sum f
  set a : ℕ → Series := fun n ↦ ((fun m ↦ f (n, m)):Series)
  have hLpos : 0 ≤ L := by
    simp [L, Sum, hf]; apply sum_of_nonneg; intro n; by_cases h: n ≥ 0 <;> simp [h]; grind
  have hfinsum (X: Finset (ℕ × ℕ)) : ∑ p ∈ X, f p ≤ L := by
    have ⟨ g, hg, hconv ⟩ := hf
    have hsum := Sum.eq hg hconv
    have hnonneg : (f ∘ g : Series).nonneg := by
      intro n
      have hpos' : ∀ (x : ℕ × ℕ), 0 ≤ f x := by
        intro x; apply hpos x.1 x.2
      by_cases h : n ≥ 0 <;> simp [h, hpos']
    choose g_inv hleft hright using bijective_iff_has_inverse.mp hg
    have hsurj : Function.Surjective g := hg.2
    let hn_of_p (p : ℕ×ℕ) : ℕ := (hsurj p).choose
    have hg_n_of_p (p : ℕ×ℕ) : g (hn_of_p p) = p := (hsurj p).choose_spec
    let N := X.sup hn_of_p
    have hN (p) (hp : p ∈ X) : hn_of_p p ≤ N := Finset.le_sup (s := X) (f := hn_of_p) hp
    have hX_subset : X ⊆ (Finset.Icc 0 N).image g := by
      intro p hp; apply Finset.mem_image.mpr
      refine ⟨ hn_of_p p, Finset.mem_Icc.mpr ⟨ by omega, hN p hp ⟩, hg_n_of_p p ⟩
    have hsum_subset : ∑ p ∈ X, f p ≤ ∑ p ∈ (Finset.Icc 0 N).image g, f p := by
      have h_sdiff_nonneg : 0 ≤ ∑ p ∈ ((Finset.Icc 0 N).image g) \ X, f p :=
        Finset.sum_nonneg fun p hp => hpos p.1 p.2
      have h_eq := Finset.sum_sdiff hX_subset (f := f)
      linarith
    calc
      ∑ p ∈ X, f p ≤ ∑ p ∈ (Finset.Icc 0 N).image g, f p := hsum_subset
      _ = ∑ n ∈ Finset.Icc 0 N, (f ∘ g) n := by
        simpa using Finset.sum_image (s := Finset.Icc 0 N) (f := f) (hg.1.injOn (s := (Finset.Icc 0 N : Set ℕ)))
      _ = (f ∘ g : Series).partial (N : ℤ) := by
        simp [Series.partial, Finset.Icc_eq_cast]
      _ ≤ (f ∘ g : Series).sum :=
        partial_le_sum_of_nonneg hnonneg (converges_of_absConverges hconv) (N : ℤ)
      _ = L := sum_of_converges hsum
  have hfinsum' (n M:ℕ) : (a n).partial M ≤ L := by
    simp [a, Series.partial, Finset.Icc_eq_cast]
    convert_to ∑ x ∈ .map (Embedding.sectR n ℕ) (.Icc 0 M), f x ≤ L
    . simp
    solve_by_elim
  have hnon (n:ℕ) : (a n).nonneg := by
    simp [a, nonneg]; intro m; split_ifs <;> simp [hpos]
  have hconv (n:ℕ) : (a n).converges := by
    rw [converges_of_nonneg_iff (hnon n)]
    use L; intro N; by_cases h: N ≥ 0
    . lift N to ℕ using h; solve_by_elim
    rw [partial_of_lt (by simp [a]; linarith)]; simp [hLpos]
  have (N M:ℤ) : ∑ n ∈ Icc 0 N, (a n.toNat).partial M ≤ L := by
    by_cases hN : N ≥ 0; swap
    . simp [Finset.Icc_empty hN, hLpos]
    lift N to ℕ using hN
    by_cases hM : M ≥ 0; swap
    . convert hLpos; unfold Series.partial
      apply sum_eq_zero; intro n _
      simp [a, Finset.Icc_empty hM]
    lift M to ℕ using hM
    convert_to ∑ x ∈ (Icc 0 N) ×ˢ (.Icc 0 M), f x ≤ L
    . simp [a, sum_product, Series.partial]
    solve_by_elim
  replace (N:ℤ) : ∑ n ∈ Icc 0 N, (a n.toNat).sum ≤ L := by
    apply le_of_tendsto' (x := .atTop) (tendsto_finset_sum _ _) (this N)
    solve_by_elim [convergesTo_sum]
  replace (N:ℤ) : (fun n ↦ (a n).sum:Series).partial N ≤ L := by
    convert this N with n hn; simp_all
  have hnon' : (fun n ↦ (a n).sum:Series).nonneg := by
    intro n; simp; split_ifs
    . exact sum_of_nonneg (hnon n.toNat)
    simp
  have hconv' : (fun n ↦ (a n).sum:Series).converges := by
    rw [converges_of_nonneg_iff hnon']; use L
  replace : (fun n ↦ (a n).sum:Series).sum ≤ L := le_of_tendsto' (convergesTo_sum hconv') this
  replace : (fun n ↦ (a n).sum:Series).sum = L := by
    apply le_antisymm this (le_of_forall_sub_le _); intro ε hε
    replace : ∃ X, ∑ p ∈ X, f p ≥ L - ε := by
      have ⟨ g, hg, hconv ⟩ := hf
      have hsum := Sum.eq hg hconv
      have hLpos : 0 ≤ L := hLpos
      have hpos_pair : ∀ (x : ℕ × ℕ), 0 ≤ f x := by
        intro x; apply hpos x.1 x.2
      have hconv_nonneg : (f ∘ g : Series).nonneg := by
        intro n; by_cases h : n ≥ 0 <;> simp [h, hpos_pair]
      have h_conv_abs := converges_of_absConverges hconv
      have h_partial_tendsto : atTop.Tendsto (λ (N : ℤ) => (f ∘ g : Series).partial N) (nhds L) := hsum
      have h_tendsto_formula := (Metric.tendsto_atTop (a := L)).mp h_partial_tendsto
      rcases h_tendsto_formula ε hε with ⟨ N, hN ⟩
      set M := max N 0 with hM_def
      have hM_nonneg : (0 : ℤ) ≤ M := by
        simp [hM_def]
      have hM_ge_N : M ≥ N := by
        simp [hM_def]
      have hM_eq_int : (Int.toNat M : ℤ) = M := Int.toNat_of_nonneg hM_nonneg
      have h_abs_bound : |(f ∘ g : Series).partial M - L| < ε := hN M hM_ge_N
      have h_partial_ge : (f ∘ g : Series).partial M ≥ L - ε := by
        by_cases h : (f ∘ g : Series).partial M ≤ L
        · have h_nonpos : (f ∘ g : Series).partial M - L ≤ 0 := by linarith
          have h_eq : |(f ∘ g : Series).partial M - L| = L - (f ∘ g : Series).partial M := by
            rw [abs_of_nonpos h_nonpos]
            ring
          rw [h_eq] at h_abs_bound
          linarith
        · have h_pos : (f ∘ g : Series).partial M - L > 0 := by linarith
          have h_eq : |(f ∘ g : Series).partial M - L| = (f ∘ g : Series).partial M - L :=
            abs_of_pos h_pos
          rw [h_eq] at h_abs_bound
          linarith
      use ((Finset.Icc 0 (Int.toNat M)).image g)
      have h_sum_eq : ∑ p ∈ ((Finset.Icc 0 (Int.toNat M)).image g), f p = (f ∘ g : Series).partial M := by
        calc
          ∑ p ∈ ((Finset.Icc 0 (Int.toNat M)).image g), f p = ∑ n ∈ Finset.Icc 0 (Int.toNat M), (f ∘ g) n := by
            have hinj : Set.InjOn g (Finset.Icc 0 (Int.toNat M) : Set ℕ) := hg.1.injOn
            rw [Finset.sum_image hinj]; rfl
          _ = (f ∘ g : Series).partial (Int.toNat M : ℤ) := by
            rw [Series.partial, Finset.Icc_eq_cast, Finset.sum_map]
            simp
          _ = (f ∘ g : Series).partial M := by rw [hM_eq_int]
      have h_goal : ∑ p ∈ ((Finset.Icc 0 (Int.toNat M)).image g), f p ≥ L - ε := by
        rw [h_sum_eq]
        exact h_partial_ge
      exact h_goal
    choose X hX using this
    have : ∃ N, ∃ M, X ⊆ (Icc 0 N) ×ˢ (Icc 0 M) := by
      have hX_fin : X = ∅ ∨ Finset.Nonempty X := Finset.eq_empty_or_nonempty X
      rcases hX_fin with (hempty | hne)
      · subst hempty; use 0, 0; simp
      · have hmax1 : ∃ N : ℕ, ∀ (p : ℕ×ℕ), p ∈ X → p.1 ≤ N := by
          use X.sup (λ p => p.1)
          intro p hp; exact Finset.le_sup (f := λ p => p.1) hp
        have hmax2 : ∃ M : ℕ, ∀ (p : ℕ×ℕ), p ∈ X → p.2 ≤ M := by
          use X.sup (λ p => p.2)
          intro p hp; exact Finset.le_sup (f := λ p => p.2) hp
        rcases hmax1 with ⟨ N, hN1 ⟩
        rcases hmax2 with ⟨ M, hM2 ⟩
        refine ⟨ N, M, λ p hp => ?_ ⟩
        have hp1_le_N : p.1 ≤ N := hN1 p hp
        have hp2_le_M : p.2 ≤ M := hM2 p hp
        simp [Finset.mem_product, Finset.mem_Icc, hp1_le_N, hp2_le_M]
    choose N M hX' using this
    calc
      _ ≤ ∑ p ∈ X, f p := hX
      _ ≤ ∑ p ∈ (Icc 0 N) ×ˢ (Icc 0 M), f p := sum_le_sum_of_subset_of_nonneg hX' (by solve_by_elim)
      _ = ∑ n ∈ Icc 0 N, ∑ m ∈ Icc 0 M, f (n, m) := sum_product _ _ _
      _ ≤ ∑ n ∈ Icc 0 N, (a n).sum := by
        apply sum_le_sum; intro n _
        convert partial_le_sum_of_nonneg (hnon n) (hconv n) M
        simp [a, Series.partial]
      _ = (fun n ↦ (a n).sum:Series).partial N := by simp [Series.partial]
      _ ≤ _ := partial_le_sum_of_nonneg hnon' hconv' _
  simp [a, hconv, ← this, Series.convergesTo_sum hconv']

/-- Theorem 8.2.2, second version -/
theorem sum_of_sum_of_AbsConvergent {f:ℕ × ℕ → ℝ} (hf:AbsConvergent f) :
  (∀ n, ((fun m ↦ f (n, m)):Series).absConverges) ∧
  (fun n ↦ ((fun m ↦ f (n, m)):Series).sum:Series).convergesTo (Sum f) := by
  set fplus := max f 0
  set fminus := max (-f) 0
  have hfplus_nonneg : ∀ n m, 0 ≤ fplus (n, m) := by intro n m; simp [fplus]
  have hfminus_nonneg : ∀ n m, 0 ≤ fminus (n, m) := by intro n m; simp [fminus]
  have hdiff : f = fplus - fminus := by
    ext x; dsimp [fplus, fminus]; by_cases h : f x ≥ 0 <;> simp [h]
  have hfplus_conv : AbsConvergent fplus := by
    have ⟨ g, hg, hconv ⟩ := hf
    refine ⟨ g, hg, ?_ ⟩
    have h_abs_conv : (f ∘ g : Series).absConverges := hconv
    have h_nonneg_fplus : ∀ n, |(fplus ∘ g) n| ≤ |(f ∘ g) n| := by
      intro n; dsimp [fplus]; by_cases h : f (g n) ≥ 0
      · simp [h]
      · have hle : f (g n) ≤ 0 := by linarith
        simp [hle, abs_nonneg]
    have h_nonneg_abs : (fplus ∘ g : Series).abs.nonneg := by
      intro n
      by_cases hn : n ≥ (fplus ∘ g : Series).abs.m
      · have : (fplus ∘ g : Series).abs.seq n = |(fplus ∘ g : Series).seq n| := by
          simp [hn]
        rw [this]; apply abs_nonneg
      · have : (fplus ∘ g : Series).abs.seq n = 0 := by
          simp [hn]
        rw [this]
    rw [absConverges, converges_of_nonneg_iff h_nonneg_abs]
    use (f ∘ g : Series).abs.sum
    intro N; by_cases hN : N ≥ 0
    · lift N to ℕ using hN
      calc
        (fplus ∘ g : Series).abs.partial (N : ℤ) = ∑ k ∈ Finset.range (N+1), |(fplus ∘ g) k| := by
          rw [partial_abs_eq_range (fplus ∘ g) N]
        _ ≤ ∑ k ∈ Finset.range (N+1), |(f ∘ g) k| :=
          Finset.sum_le_sum (λ k hk => h_nonneg_fplus k)
        _ = (f ∘ g : Series).abs.partial (N : ℤ) := by
          rw [partial_abs_eq_range (f ∘ g) N]
        _ ≤ (f ∘ g : Series).abs.sum :=
          partial_le_sum_of_nonneg (by
            intro n; dsimp [Series.nonneg, Series.abs, Series.mk']; split_ifs <;> simp) h_abs_conv (N : ℤ)
    · have hN_lt : N < 0 := by omega
      have h_partial_zero : (fplus ∘ g : Series).abs.partial N = 0 :=
        Series.partial_of_lt (by
          have hm : (fplus ∘ g : Series).abs.m = 0 := rfl
          omega)
      rw [h_partial_zero]
      have h_nonneg_sum : 0 ≤ (f ∘ g : Series).abs.sum := by
        by_contra! h_neg
        have hpos : 0 < -(f ∘ g : Series).abs.sum / 2 := by nlinarith
        have h_event : ∀ᶠ N in atTop, dist ((f ∘ g : Series).abs.partial N) ((f ∘ g : Series).abs.sum) < -(f ∘ g : Series).abs.sum / 2 :=
          (Metric.tendsto_nhds.mp (convergesTo_sum h_abs_conv)) (-(f ∘ g : Series).abs.sum / 2) hpos
        rcases (by simpa [Filter.eventually_atTop] using h_event) with ⟨ N, hN ⟩
        have hN_bound : dist ((f ∘ g : Series).abs.partial N) ((f ∘ g : Series).abs.sum) < -(f ∘ g : Series).abs.sum / 2 :=
          hN N (le_refl N)
        have h_nonneg_N : 0 ≤ (f ∘ g : Series).abs.partial N := by
          apply Finset.sum_nonneg; intro n hn
          by_cases hn' : n ≥ (f ∘ g : Series).abs.m
          · simp [hn']
          · simp [hn']
        have hN_bound' : |(f ∘ g : Series).abs.partial N - (f ∘ g : Series).abs.sum| < -(f ∘ g : Series).abs.sum / 2 := by
          simpa [Real.dist_eq] using hN_bound
        have hdiff_pos : 0 < (f ∘ g : Series).abs.partial N - (f ∘ g : Series).abs.sum := by
          linarith
        have hpos_abs : |(f ∘ g : Series).abs.partial N - (f ∘ g : Series).abs.sum| =
          (f ∘ g : Series).abs.partial N - (f ∘ g : Series).abs.sum :=
          abs_of_pos hdiff_pos
        rw [hpos_abs] at hN_bound'
        nlinarith
      exact h_nonneg_sum
  have hfminus_conv : AbsConvergent fminus := by
    have ⟨ g, hg, hconv ⟩ := hf
    refine ⟨ g, hg, ?_ ⟩
    have h_abs_conv : (f ∘ g : Series).absConverges := hconv
    have h_nonneg_fminus : ∀ n, |(fminus ∘ g) n| ≤ |(f ∘ g) n| := by
      intro n; dsimp [fminus]; by_cases h : f (g n) ≥ 0
      · simp [h]
      · have hpos : -f (g n) ≥ 0 := by linarith
        simp [hpos, abs_nonneg]
    have h_nonneg_abs : (fminus ∘ g : Series).abs.nonneg := by
      intro n
      by_cases hn : n ≥ (fminus ∘ g : Series).abs.m
      · have : (fminus ∘ g : Series).abs.seq n = |(fminus ∘ g : Series).seq n| := by
          simp [hn]
        rw [this]; apply abs_nonneg
      · have : (fminus ∘ g : Series).abs.seq n = 0 := by
          simp [hn]
        rw [this]
    rw [absConverges, converges_of_nonneg_iff h_nonneg_abs]
    use (f ∘ g : Series).abs.sum
    intro N; by_cases hN : N ≥ 0
    · lift N to ℕ using hN
      calc
        (fminus ∘ g : Series).abs.partial (N : ℤ) = ∑ k ∈ Finset.range (N+1), |(fminus ∘ g) k| := by
          rw [partial_abs_eq_range (fminus ∘ g) N]
        _ ≤ ∑ k ∈ Finset.range (N+1), |(f ∘ g) k| :=
          Finset.sum_le_sum (λ k hk => h_nonneg_fminus k)
        _ = (f ∘ g : Series).abs.partial (N : ℤ) := by
          rw [partial_abs_eq_range (f ∘ g) N]
        _ ≤ (f ∘ g : Series).abs.sum :=
          partial_le_sum_of_nonneg (by
            intro n; dsimp [Series.nonneg, Series.abs, Series.mk']; split_ifs <;> simp) h_abs_conv (N : ℤ)
    · have hN_lt : N < 0 := by omega
      have h_partial_zero : (fminus ∘ g : Series).abs.partial N = 0 :=
        Series.partial_of_lt (by
          have hm : (fminus ∘ g : Series).abs.m = 0 := rfl
          omega)
      rw [h_partial_zero]
      have h_nonneg_sum : 0 ≤ (f ∘ g : Series).abs.sum := by
        by_contra! h_neg
        have hpos : 0 < -(f ∘ g : Series).abs.sum / 2 := by nlinarith
        have h_event : ∀ᶠ N in atTop, dist ((f ∘ g : Series).abs.partial N) ((f ∘ g : Series).abs.sum) < -(f ∘ g : Series).abs.sum / 2 :=
          (Metric.tendsto_nhds.mp (convergesTo_sum h_abs_conv)) (-(f ∘ g : Series).abs.sum / 2) hpos
        rcases (by simpa [Filter.eventually_atTop] using h_event) with ⟨ N, hN ⟩
        have hN_bound : dist ((f ∘ g : Series).abs.partial N) ((f ∘ g : Series).abs.sum) < -(f ∘ g : Series).abs.sum / 2 :=
          hN N (le_refl N)
        have h_nonneg_N : 0 ≤ (f ∘ g : Series).abs.partial N := by
          apply Finset.sum_nonneg; intro n hn
          by_cases hn' : n ≥ (f ∘ g : Series).abs.m
          · simp [hn']
          · simp [hn']
        have hN_bound' : |(f ∘ g : Series).abs.partial N - (f ∘ g : Series).abs.sum| < -(f ∘ g : Series).abs.sum / 2 := by
          simpa [Real.dist_eq] using hN_bound
        have hdiff_pos : 0 < (f ∘ g : Series).abs.partial N - (f ∘ g : Series).abs.sum := by
          linarith
        have hpos_abs : |(f ∘ g : Series).abs.partial N - (f ∘ g : Series).abs.sum| =
          (f ∘ g : Series).abs.partial N - (f ∘ g : Series).abs.sum :=
          abs_of_pos hdiff_pos
        rw [hpos_abs] at hN_bound'
        nlinarith
      exact h_nonneg_sum
  choose hfplus_conv' hfplus_sum using sum_of_sum_of_AbsConvergent_nonneg hfplus_conv hfplus_nonneg
  choose hfminus_conv' hfminus_sum using sum_of_sum_of_AbsConvergent_nonneg hfminus_conv hfminus_nonneg
  split_ands
  . intro n
    have hplus_absConv : ((fun m ↦ fplus (n, m)):Series).absConverges := by
      let s : Series := (fun m ↦ fplus (n, m))
      have h_eq : s.abs = s := by
        apply Series.ext
        · rfl
        · funext i; dsimp [s]; by_cases hi : i ≥ 0
          · simp [hi, abs_of_nonneg (hfplus_nonneg n (i.toNat))]
          · simp [hi]
      have h_s_conv : s.converges := by simpa [s] using hfplus_conv' n
      simpa [absConverges, s, h_eq] using h_s_conv
    have hminus_absConv : ((fun m ↦ fminus (n, m)):Series).absConverges := by
      let s : Series := (fun m ↦ fminus (n, m))
      have h_eq : s.abs = s := by
        apply Series.ext
        · rfl
        · funext i; dsimp [s]; by_cases hi : i ≥ 0
          · simp [hi, abs_of_nonneg (hfminus_nonneg n (i.toNat))]
          · simp [hi]
      have h_s_conv : s.converges := by simpa [s] using hfminus_conv' n
      simpa [absConverges, s, h_eq] using h_s_conv
    have h_nonneg_abs : ((fun m ↦ f (n, m)):Series).abs.nonneg := by
      intro n'; by_cases hi : n' ≥ 0
      · simp [hi, abs_nonneg]
      · simp [hi]
    rw [absConverges, converges_of_nonneg_iff h_nonneg_abs]
    use ((fun m ↦ fplus (n, m)):Series).abs.sum + ((fun m ↦ fminus (n, m)):Series).abs.sum
    intro N; by_cases hN : N ≥ 0
    · lift N to ℕ using hN
      have h_ineq : ∀ (m : ℤ), |f (n, m.toNat)| ≤ |fplus (n, m.toNat)| + |fminus (n, m.toNat)| := by
        intro m; by_cases h : f (n, m.toNat) ≥ 0
        · have h_fplus : fplus (n, m.toNat) = f (n, m.toNat) := by simp [fplus, h]
          have h_fminus : fminus (n, m.toNat) = 0 := by simp [fminus, h]
          simp [h_fplus, h_fminus]
        · have h_fplus : fplus (n, m.toNat) = 0 := by
            simp [fplus, show f (n, m.toNat) ≤ 0 from by linarith]
          have h_fminus : fminus (n, m.toNat) = -f (n, m.toNat) := by
            simp [fminus, show -f (n, m.toNat) ≥ 0 from by linarith]
          simp [h_fplus, h_fminus, abs_neg]
      calc
        ((fun m ↦ f (n, m)):Series).abs.partial (N : ℤ) = ∑ k ∈ Finset.range (N+1), |f (n, k)| := by
          rw [partial_abs_eq_range (fun m ↦ f (n, m)) N]
        _ ≤ ∑ k ∈ Finset.range (N+1), (|fplus (n, k)| + |fminus (n, k)|) :=
          Finset.sum_le_sum (λ k hk => h_ineq (k : ℤ))
        _ = (∑ k ∈ Finset.range (N+1), |fplus (n, k)|) + (∑ k ∈ Finset.range (N+1), |fminus (n, k)|) := by
          simp [Finset.sum_add_distrib]
        _ = ((fun m ↦ fplus (n, m)):Series).abs.partial (N : ℤ) + ((fun m ↦ fminus (n, m)):Series).abs.partial (N : ℤ) := by
          simp [partial_abs_eq_range (fun m ↦ fplus (n, m)) N, partial_abs_eq_range (fun m ↦ fminus (n, m)) N]
        _ ≤ ((fun m ↦ fplus (n, m)):Series).abs.sum + ((fun m ↦ fminus (n, m)):Series).abs.sum := by
          have hp1 : ((fun m ↦ fplus (n, m)):Series).abs.partial (N : ℤ) ≤ ((fun m ↦ fplus (n, m)):Series).abs.sum :=
            partial_le_sum_of_nonneg (by intro n'; by_cases hi : n' ≥ 0 <;> simp [hi]) hplus_absConv (N : ℤ)
          have hp2 : ((fun m ↦ fminus (n, m)):Series).abs.partial (N : ℤ) ≤ ((fun m ↦ fminus (n, m)):Series).abs.sum :=
            partial_le_sum_of_nonneg (by intro n'; by_cases hi : n' ≥ 0 <;> simp [hi]) hminus_absConv (N : ℤ)
          nlinarith
    · have hN_lt : N < 0 := by omega
      have h_partial_zero_f : ((fun m ↦ f (n, m)):Series).abs.partial N = 0 :=
        Series.partial_of_lt (by
          have hm : ((fun m ↦ f (n, m)):Series).abs.m = 0 := rfl
          omega)
      have h_partial_zero : ((fun m ↦ fplus (n, m)):Series).abs.partial N = 0 :=
        Series.partial_of_lt (by
          have hm : ((fun m ↦ fplus (n, m)):Series).abs.m = 0 := rfl
          omega)
      have h_partial_zero' : ((fun m ↦ fminus (n, m)):Series).abs.partial N = 0 :=
        Series.partial_of_lt (by
          have hm : ((fun m ↦ fminus (n, m)):Series).abs.m = 0 := rfl
          omega)
      have h_nonneg_sum : 0 ≤ ((fun m ↦ fplus (n, m)):Series).abs.sum := by
        apply ge_of_tendsto (convergesTo_sum hplus_absConv)
        have h_nonneg_partial : ∀ N' : ℤ, 0 ≤ ((fun m ↦ fplus (n, m)):Series).abs.partial N' := by
          intro N'
          dsimp [Series.partial]
          apply Finset.sum_nonneg; intro n' hn'
          by_cases hi : n' ≥ 0 <;> simp [hi, abs_nonneg]
        refine Filter.eventually_atTop.mpr ⟨0, λ N' hN' => h_nonneg_partial N'⟩
      have h_nonneg_sum' : 0 ≤ ((fun m ↦ fminus (n, m)):Series).abs.sum := by
        apply ge_of_tendsto (convergesTo_sum hminus_absConv)
        have h_nonneg_partial : ∀ N' : ℤ, 0 ≤ ((fun m ↦ fminus (n, m)):Series).abs.partial N' := by
          intro N'
          dsimp [Series.partial]
          apply Finset.sum_nonneg; intro n' hn'
          by_cases hi : n' ≥ 0 <;> simp [hi, abs_nonneg]
        refine Filter.eventually_atTop.mpr ⟨0, λ N' hN' => h_nonneg_partial N'⟩
      rw [h_partial_zero_f]
      nlinarith [h_nonneg_sum, h_nonneg_sum']
  convert convergesTo.sub hfplus_sum hfminus_sum using 1
  . -- encountered surprising difficulty with definitional equivalence here
    simp [hdiff]
    change (fun n ↦ ((fun m ↦ (fplus - fminus) (n, m)):Series).sum:Series) =
      (fun n ↦ ((fun m ↦ fplus (n, m)):Series).sum:Series)
      - (fun n ↦ ((fun m ↦ (fminus) (n, m)):Series).sum:Series)
    convert_to (fun n ↦ ((fun m ↦ (fplus - fminus) (n, m)):Series).sum:Series) =
      (((fun n ↦ ((fun m ↦ fplus (n, m)):Series).sum) - (fun n ↦ ((fun m ↦ (fminus) (n, m)):Series).sum):ℕ → ℝ):Series)
    . convert sub_coe _ _
    rcongr _ n; simp
    convert (sub _ _).2 with m; rfl
    split_ifs with h <;> simp [h, HSub.hSub, Sub.sub]
    . solve_by_elim
    convert hfminus_conv' n.toNat
  have ⟨ g, hg, _ ⟩ := hf
  have h1 := Sum.eq hg (hf.comp hg)
  have hplus := Sum.eq hg (hfplus_conv.comp hg)
  have hminus := Sum.eq hg (hfminus_conv.comp hg)
  apply convergesTo_uniq h1 _
  convert (convergesTo.sub hplus hminus) using 3 with n
  split_ifs with h <;> simp [h, hdiff, HSub.hSub, Sub.sub]

/-- Theorem 8.2.2, third version -/
theorem sum_of_sum_of_AbsConvergent' {f:ℕ × ℕ → ℝ} (hf:AbsConvergent f) :
  (∀ m, ((fun n ↦ f (n, m)):Series).absConverges) ∧
  (fun m ↦ ((fun n ↦ f (n, m)):Series).sum:Series).convergesTo (Sum f) := by
  set π: ℕ × ℕ → ℕ × ℕ := fun p ↦ (p.2, p.1)
  have hπ: Bijective π := Involutive.bijective (congrFun rfl)
  have ⟨ g, hg, hconv ⟩ := hf
  convert sum_of_sum_of_AbsConvergent (f := f ∘ π) _ using 2
  . exact (Sum.of_comp hf hπ).2
  refine ⟨ _, hπ.comp hg, ?_ ⟩
  convert hconv using 2

/-- Theorem 8.2.2, fourth version -/
theorem sum_comm {f:ℕ × ℕ → ℝ} (hf:AbsConvergent f) :
  (fun n ↦ ((fun m ↦ f (n, m)):Series).sum:Series).sum = (fun m ↦ ((fun n ↦ f (n, m)):Series).sum:Series).sum := by
  simp [sum_of_converges (sum_of_sum_of_AbsConvergent hf).2,
        sum_of_converges (sum_of_sum_of_AbsConvergent' hf).2]

abbrev AbsConvergent' {X:Type} (f: X → ℝ) : Prop := BddAbove ( (fun A ↦ ∑ x ∈ A, |f x|) '' .univ )

theorem AbsConvergent'.of_finite {X:Type} [Finite X] (f:X → ℝ) : AbsConvergent' f := by
  have _ := Fintype.ofFinite X
  simp [bddAbove_def]; use ∑ x, |f x|; intro A; apply Finset.sum_le_univ_sum_of_nonneg; simp

/-- Lemma 8.2.3 / Exercise 8.2.1 -/
theorem AbsConvergent.iff {X:Type} (hX:CountablyInfinite X) (f : X → ℝ) :
  AbsConvergent f ↔ BddAbove ( (fun A ↦ ∑ x ∈ A, |f x|) '' .univ ) := by
  constructor
  · intro hf
    rcases hf with ⟨g, hg, hfg⟩
    have hg_inj : Function.Injective g := hg.1
    have hg_surj : Function.Surjective g := hg.2
    have h_nonneg : (f ∘ g : Series).abs.nonneg := by
      intro n; simp [Series.nonneg, Series.abs, Series.mk']; split_ifs; exact abs_nonneg _; rfl
    rcases (converges_of_nonneg_iff h_nonneg).mp hfg with ⟨M, hM⟩
    rw [bddAbove_def]
    use M
    intro y hy
    rcases hy with ⟨A, -, rfl⟩
    classical
    by_cases hA : A.Nonempty
    · choose g_inv hg_inv_spec using hg_surj
      have hg_g_inv (x : X) : g (g_inv x) = x := hg_inv_spec x
      let g_emb : ℕ ↪ X := ⟨g, hg_inj⟩
      let N := A.sup g_inv
      have hN_bound (x) (hx : x ∈ A) : g_inv x ≤ N := Finset.le_sup (f := g_inv) hx
      have hA_subset : A ⊆ Finset.map g_emb (Finset.Icc 0 N) := by
        intro x hx
        refine Finset.mem_map.mpr ⟨g_inv x, Finset.mem_Icc.mpr ⟨by omega, hN_bound x hx⟩, ?_⟩
        simp [g_emb, hg_g_inv x]
      have hsum_subset : ∑ x ∈ A, |f x| ≤ ∑ x ∈ Finset.map g_emb (Finset.Icc 0 N), |f x| := by
        have h_sdiff_nonneg : 0 ≤ ∑ x ∈ (Finset.map g_emb (Finset.Icc 0 N)) \ A, |f x| :=
          Finset.sum_nonneg (by intro x _; exact abs_nonneg _)
        have h_eq := Finset.sum_sdiff hA_subset (f := |f|)
        have h_eq' : ∑ x ∈ (Finset.map g_emb (Finset.Icc 0 N)) \ A, |f x| + ∑ x ∈ A, |f x|
            = ∑ x ∈ Finset.map g_emb (Finset.Icc 0 N), |f x| := by simpa using h_eq
        linarith
      calc
        ∑ x ∈ A, |f x| ≤ ∑ x ∈ Finset.map g_emb (Finset.Icc 0 N), |f x| := hsum_subset
        _ = ∑ n ∈ Finset.Icc 0 N, |f (g n)| := by
          simp [Finset.sum_map, g_emb]
        _ = (f ∘ g : Series).abs.partial (N : ℤ) := by
          simp [Series.partial, Series.abs, Series.mk', Finset.Icc_eq_cast]
        _ ≤ M := hM (N : ℤ)
    · simp at hA
      have hM_nonneg : 0 ≤ M := by
        have h0 := hM (0 : ℤ)
        have hpos : 0 ≤ (f ∘ g : Series).abs.partial (0 : ℤ) := by
          apply Finset.sum_nonneg; intro i _; exact h_nonneg i
        linarith
      simp [hA, hM_nonneg]
  · intro hf
    simp [bddAbove_def] at hf
    choose L hL using hf
    have ⟨ g, hg ⟩ := hX.symm
    refine ⟨ g, hg, ?_ ⟩
    unfold absConverges
    rw [converges_of_nonneg_iff]
    · use L
      intro N
      by_cases hN: N ≥ 0
      · lift N to ℕ using hN
        set g' := Embedding.mk g hg.1
        convert hL (map g' (Icc 0 N))
        simp [Series.partial]; rfl
      · convert hL ∅
        simp; apply partial_of_lt; grind
    · simp [nonneg]
      intro n; by_cases h: n ≥ 0 <;> simp [h]

/-- Not in textbook, but should have been included. -/
theorem AbsConvergent'.of_countable {X:Type} (hX:CountablyInfinite X) {f:X → ℝ} :
  AbsConvergent' f ↔ AbsConvergent f := (AbsConvergent.iff hX f).symm

/-- Connection with Mathlib's {name}`Summable` property. Some version of this might be suitable
    for Mathlib? -/
theorem AbsConvergent'.iff_Summable {X:Type} (f:X → ℝ) : AbsConvergent' f ↔ Summable f := by
  simp [←summable_abs_iff, AbsConvergent']
  simp [summable_iff_vanishing_norm]
  classical
  constructor
  . intro h ε hε
    set s := Set.range fun A ↦ ∑ x ∈ A, |f x|
    have hnon : s.Nonempty := by simp [s]; use 0, ∅; simp
    have : (sSup s)-ε < sSup s := by linarith
    simp [lt_csSup_iff h hnon,s] at this; choose S hS using this
    use S; intro T hT
    rw [abs_of_nonneg (by positivity)]
    have : ∑ x ∈ T, |f x| + ∑ x ∈ S, |f x| ≤ sSup s := by
      apply le_csSup h
      simp [s]; exact ⟨ T ∪ S, sum_union hT ⟩
    linarith
  intro h; choose S hS using h 1 (by norm_num)
  rw [bddAbove_def]
  use ∑ x ∈ S, |f x| + 1; simp; intro T
  calc
    _ = ∑ x ∈ (T ∩ S), |f x| + ∑ x ∈ (T \ S), |f x| := (sum_inter_add_sum_diff _ _ _).symm
    _ ≤ _ := by
      gcongr
      . exact inter_subset_right
      apply le_of_lt (lt_of_abs_lt (hS _ disjoint_sdiff_self_left))

/-- Lemma 8.2.5 / Exercise 8.2.2-/
theorem AbsConvergent'.countable_supp {X:Type} {f:X → ℝ} (hf: AbsConvergent' f) :
  AtMostCountable { x | f x ≠ 0 } := by
    have h_summable_abs : Summable (|f|) := by
      have h_sf : Summable f := (Chapter8.AbsConvergent'.iff_Summable (X := X) (f := f)).mp hf
      exact (summable_abs_iff (f := f)).mpr h_sf
    have h_finite (k : ℕ) : Set.Finite { x | |f x| > 1 / ((k : ℝ) + 1) } := by
      rcases ((summable_iff_vanishing_norm (f := |f|)).mp h_summable_abs) (1 / ((k : ℝ) + 1)) (by positivity) with ⟨ S, hS ⟩
      have h_subset : { x | |f x| > 1 / ((k : ℝ) + 1) } ⊆ (S : Set X) := by
        intro x hx
        by_contra! hxS
        have h_T : Disjoint ({x} : Finset X) S := by
          have hxS' : x ∉ S := by simpa using hxS
          simp [Finset.disjoint_singleton_left, hxS']
        have h_sum' : |f x| < 1 / ((k : ℝ) + 1) := by
          simpa using hS {x} h_T
        have hx_val : |f x| > 1 / ((k : ℝ) + 1) := hx
        exact lt_irrefl _ (lt_trans h_sum' hx_val)
      exact Set.Finite.subset (Finset.finite_toSet S) h_subset
    have h_countable : Set.Countable { x | f x ≠ 0 } := by
      have h_union : { x | f x ≠ 0 } ⊆ ⋃ (k : ℕ), { x | |f x| > 1 / ((k : ℝ) + 1) } := by
        intro x hx
        have hx' : |f x| > 0 := abs_pos.mpr hx
        have : ∃ k : ℕ, 1 / ((k : ℝ) + 1) < |f x| :=
          exists_nat_one_div_lt hx'
        rcases this with ⟨ k, hk ⟩
        exact Set.mem_iUnion.mpr ⟨ k, hk ⟩
      refine Set.Countable.mono h_union (Set.countable_iUnion (λ n => ?_))
      exact (h_finite n).countable
    rw [AtMostCountable.iff]; exact h_countable

/-- Compare with Mathlib's {name}`Summable.subtype`-/
theorem AbsConvergent'.subtype {X:Type} {f:X → ℝ} (hf: AbsConvergent' f) (A: Set X) :
  AbsConvergent' (fun x:A ↦ f x) := by
  apply BddAbove.mono _ hf
  intro z hz; simp at *; choose A hA using hz
  use A.map (Embedding.subtype _); simp [hA]

/-- A generalized sum.  Note that this will give junk values if {name}`f` is not {name}`AbsConvergent'`. -/
noncomputable abbrev Sum' {X:Type} (f: X → ℝ) : ℝ := Sum (fun x : { x | f x ≠ 0 } ↦ f x)

/-- Not in textbook, but should have been included (the series laws are significantly harder
to establish without this) -/
theorem Sum'.of_finsupp {X:Type} {f:X → ℝ} {A: Finset X} (h: ∀ x ∉ A, f x = 0) : Sum' f = ∑ x ∈ A, f x := by
  unfold Sum'
  set E := { x | f x ≠ 0 }
  have hE : E ⊆ A := by intro _; simp [E]; grind
  have hfin : Finite E := Finite.Set.subset _ hE
  set E' := E.toFinite.toFinset
  rw [Sum.of_finite (fun x:E ↦ f x), ←E'.sum_subtype (by simp [E'])]
  replace hE : E' ⊆ A := by aesop
  apply sum_subset hE; aesop

/-- Not in textbook, but should have been included (the series laws are significantly harder
to establish without this) -/
theorem Sum'.of_countable_supp {X:Type} {f:X → ℝ} {A: Set X} (hA: CountablyInfinite A)
  (hfA : ∀ x ∉ A, f x = 0) (hconv: AbsConvergent' f):
  AbsConvergent' (fun x:A ↦ f x) ∧ Sum' f = Sum (fun x:A ↦ f x) := by
  -- We can adapt the proof of `AbsConvergent'.of_countable` to establish absolute convergence on A.
  have hconv' : AbsConvergent (fun x:A ↦ f x) :=
    (AbsConvergent'.of_countable hA).mp (hconv.subtype A)
  rw [AbsConvergent'.of_countable hA]
  refine ⟨ hconv', ?_ ⟩
  set E := { x | f x ≠ 0 }
  -- The main challenge here is to relate a sum on E with a sum on A.  First, we show containment.
  have hE : E ⊆ A := by intro _; simp [E]; by_contra!; aesop
  -- Now, we map A back to the natural numbers, thus identifying E with a subset E' of ℕ.
  choose g hg using hA.symm
  have hsum := Sum.eq hg (hconv'.comp hg)
  set E' := { n | ↑(g n) ∈ E }
  set ι : E' → E := fun ⟨ n, hn ⟩ ↦ ⟨ g n, by aesop ⟩
  have hι: Bijective ι := by
    split_ands
    . intro ⟨ _, _ ⟩ ⟨ _, _ ⟩ h; simp [ι, E', Subtype.val_inj] at *; exact hg.1 h
    . intro ⟨ x, hx ⟩; choose n hn using hg.2 ⟨ _, hE hx ⟩; use ⟨ n, by aesop ⟩; grind
  -- The cases of infinite and finite E' are handled separately.
  obtain hE' | hE' := Nat.atMostCountable_subset E'
  . --   use Nat.monotone_enum_of_infinite to enumerate E'
    --   show the partial sums of E' are a subsequence of the partial sums of A
    set hinf : Infinite E' := hE'.toInfinite
    choose a ha_bij ha_mono using (Nat.monotone_enum_of_infinite E').exists
    have : atTop.Tendsto (Nat.cast ∘ Subtype.val ∘ a: ℕ → ℤ) atTop := by
      apply tendsto_natCast_atTop_atTop.comp (StrictMono.tendsto_atTop _)
      intro _ _ hnm; simp [ha_mono hnm]
    apply tendsto_nhds_unique  _ (hsum.comp this)
    have hconv'' : AbsConvergent (fun x:E ↦ f x) := by
      rw [←AbsConvergent'.of_countable]
      . exact hconv.subtype E
      apply (CountablyInfinite.equiv _).mp hE'; use ι
    replace := Sum.eq (hι.comp ha_bij) (hconv''.comp (hι.comp ha_bij))
    convert this.comp tendsto_natCast_atTop_atTop using 1; ext N
    simp [Series.partial, ι]
    calc
      _ = ∑ x ∈ .image (Subtype.val ∘ a) (.Icc 0 N), f ↑(g x) := by
        symm; apply sum_subset
        . intro m hm; simp at hm ⊢; obtain ⟨ n, hn, rfl ⟩ := hm
          simp [ha_mono.monotone hn]
        intro x hx hx'; simp at hx hx'; contrapose! hx'
        choose n hn using (hι.comp ha_bij).2 ⟨ g x, hx' ⟩
        simp [ι, Subtype.val_inj] at hn
        apply hg.1 at hn; subst hn
        use n; simpa [ha_mono.le_iff_le] using hx
      _ = _ := by
        apply sum_image
        intro _ _ _ _ h; simp [Subtype.val_inj] at h; exact ha_bij.1 h
  -- When E' is finite, we show that all sufficiently large partial sums of A are equal to
  -- the sum of E'.
  let hEfin : Finite E := hι.finite_iff.mp hE'
  let hE'fintype : Fintype E' := .ofFinite _
  let hEfintype : Fintype E := .ofFinite _
  apply convergesTo_uniq _ hsum
  simp [Sum.of_finite, Series.convergesTo]
  apply tendsto_nhds_of_eventually_eq
  have hE'bound : BddAbove E' := Set.Finite.bddAbove hE'
  rw [bddAbove_def] at hE'bound; choose N hN using hE'bound
  rw [eventually_atTop]
  use N; intro N' hN'
  lift N' to ℕ using (LE.le.trans (by positivity) hN')
  simp [Series.partial] at hN' ⊢
  calc
    _ = ∑ n ∈ E', f (g n) := by
      symm; apply sum_subset
      . intro x hx; simp at *; linarith [hN _ hx]
      intro _ _ hx'; simpa [E',E] using hx'
    _ = ∑ n:E', f (g n) := by convert (sum_set_coe _).symm
    _ = ∑ n, f (ι n) := sum_congr rfl (by grind)
    _ = _ := hι.sum_comp (g := fun x ↦ f x)

/-- Maybe suitable for porting to Mathlib?-/
theorem Filter.Eventually.int_natCast_atTop (p: ℤ → Prop) :
  (∀ᶠ n in .atTop, p n) ↔ ∀ᶠ n:ℕ in .atTop, p ↑n := by
  refine ⟨ Eventually.natCast_atTop, ?_ ⟩
  simp [eventually_atTop]
  intro N hN; use N; intro n hn
  lift n to ℕ using (by omega)
  simp at hn; solve_by_elim

theorem Filter.Tendsto.int_natCast_atTop {R:Type} (f: ℤ → R) (l: Filter R) :
atTop.Tendsto f l ↔ atTop.Tendsto (f ∘ Nat.cast) l := by
  simp [tendsto_iff_eventually]
  peel with p h
  simp [←eventually_atTop]
  convert Eventually.int_natCast_atTop _


/-- Connection with Mathlib's {name}`tsum` (or {kw (of := «termΣ'_,_»)}`Σ'`) operation -/
theorem Sum'.eq_tsum {X:Type} (f:X → ℝ) (h: AbsConvergent' f) :
  Sum' f = ∑' x, f x := by
  set E := {x | f x ≠ 0}
  obtain hE | hE := h.countable_supp
  . simp [Sum']
    choose g hg using hE.symm
    have : ((f ∘ Subtype.val) ∘ g:Series).absConverges := by
      apply AbsConvergent.comp hg
      rw [←AbsConvergent'.of_countable hE]
      exact h.subtype E
    replace this := Sum.eq hg this
    convert convergesTo_uniq this _ using 1
    · replace : ∑' x, f x = ∑' n, f (g n) := calc
        _ = ∑' x:E, f x := by
          exact (tsum_subtype_eq_of_support_subset (fun x hx => hx)).symm
        _ = _ := (Equiv.tsum_eq (Equiv.ofBijective _ hg) _).symm
      rw [this]
      unfold convergesTo; rw [Filter.Tendsto.int_natCast_atTop]
      convert (Summable.tendsto_sum_tsum_nat ?_).comp (tendsto_add_atTop_nat 1) with n
      . ext N; simp [Series.partial, Nat.range_succ_eq_Icc_zero]
      rw [AbsConvergent'.iff_Summable] at h
      exact h.comp_injective (i := Subtype.val ∘ g) (Subtype.val_injective.comp hg.1)
  rw [of_finsupp (A := E.toFinite.toFinset)]; symm; apply tsum_eq_sum
  all_goals simp [E]


/-- Proposition 8.2.6 (a) (Absolutely convergent series laws) / Exercise 8.2.3 -/
theorem Sum'.add {X:Type} {f g:X → ℝ} (hf: AbsConvergent' f) (hg: AbsConvergent' g) :
  AbsConvergent' (f+g) ∧ Sum' (f + g) = Sum' f + Sum' g := by
  have h_sum_f : Summable f := (AbsConvergent'.iff_Summable f).mp hf
  have h_sum_g : Summable g := (AbsConvergent'.iff_Summable g).mp hg
  have h_sum_fg : Summable (f + g) := h_sum_f.add h_sum_g
  have h_abs_conv : AbsConvergent' (f + g) := (AbsConvergent'.iff_Summable (f + g)).mpr h_sum_fg
  have h_sum' : Sum' (f + g) = Sum' f + Sum' g := by
    calc
      Sum' (f + g) = ∑' x, (f + g) x := Sum'.eq_tsum (f + g) h_abs_conv
      _ = (∑' x, f x) + (∑' x, g x) := by
        simpa using (h_sum_f.hasSum.add h_sum_g.hasSum).tsum_eq
      _ = Sum' f + Sum' g := by rw [Sum'.eq_tsum f hf, Sum'.eq_tsum g hg]
  exact ⟨ h_abs_conv, h_sum' ⟩

/-- Proposition 8.2.6 (b) (Absolutely convergent series laws) / Exercise 8.2.3 -/
theorem Sum'.smul {X:Type} {f:X → ℝ} (hf: AbsConvergent' f) (c: ℝ) :
  AbsConvergent' (c • f) ∧ Sum' (c • f) = c * Sum' f := by
  have h_sum_f : Summable f := (AbsConvergent'.iff_Summable f).mp hf
  have h_sum_cf : Summable (c • f) := h_sum_f.const_smul c
  have h_abs_conv : AbsConvergent' (c • f) := (AbsConvergent'.iff_Summable (c • f)).mpr h_sum_cf
  have h_sum' : Sum' (c • f) = c * Sum' f := by
    calc
      Sum' (c • f) = ∑' x, (c • f) x := Sum'.eq_tsum (c • f) h_abs_conv
      _ = ∑' x, c * f x := rfl
      _ = c * ∑' x, f x := by rw [tsum_mul_left]
      _ = c * Sum' f := by rw [Sum'.eq_tsum f hf]
  exact ⟨ h_abs_conv, h_sum' ⟩

/-- This law is not explicitly stated in Proposition 8.2.6, but follows easily from parts (a) and (b).-/
theorem Sum'.sub {X:Type} {f g:X → ℝ} (hf: AbsConvergent' f) (hg: AbsConvergent' g) :
  AbsConvergent' (f-g) ∧ Sum' (f - g) = Sum' f - Sum' g := by
  convert add hf (smul hg (-1)).1 using 2
  . simp; abel
  . congr; simp; abel
  rw [(smul hg (-1)).2]; ring

/-- Proposition 8.2.6 (c) (Absolutely convergent series laws) / Exercise 8.2.3.  The first
    part of this proposition has been moved to {lean}`AbsConvergent'.subtype`. -/
theorem Sum'.of_disjoint_union {X:Type} {f:X → ℝ} (hf: AbsConvergent' f) {X₁ X₂ : Set X} (hdisj: Disjoint X₁ X₂):
  Sum' (fun x: (X₁ ∪ X₂: Set X) ↦ f x) = Sum' (fun x : X₁ ↦ f x) + Sum' (fun x : X₂ ↦ f x) := by
  have hsum_f : Summable f := (AbsConvergent'.iff_Summable f).mp hf
  have hsum_union : Summable (λ x : (X₁ ∪ X₂ : Set X) => f x) := hsum_f.comp_injective Subtype.val_injective
  have hsum_X1 : Summable (λ x : X₁ => f x) := hsum_f.comp_injective Subtype.val_injective
  have hsum_X2 : Summable (λ x : X₂ => f x) := hsum_f.comp_injective Subtype.val_injective
  have h_abs_conv_union : AbsConvergent' (fun x : (X₁ ∪ X₂ : Set X) ↦ f x) :=
    (AbsConvergent'.iff_Summable _).mpr hsum_union
  calc
    Sum' (fun x : (X₁ ∪ X₂ : Set X) ↦ f x) = ∑' x : (X₁ ∪ X₂ : Set X), f x :=
      Sum'.eq_tsum _ h_abs_conv_union
    _ = (∑' x : X₁, f x) + (∑' x : X₂, f x) := by
      rw [Summable.tsum_union_disjoint hdisj hsum_X1 hsum_X2]
    _ = Sum' (fun x : X₁ ↦ f x) + Sum' (fun x : X₂ ↦ f x) := by
      rw [← Sum'.eq_tsum (λ x : X₁ => f x) ((AbsConvergent'.iff_Summable _).mpr hsum_X1),
        ← Sum'.eq_tsum (λ x : X₂ => f x) ((AbsConvergent'.iff_Summable _).mpr hsum_X2)]

/-- This technical claim, the analogue of {name}`tsum_univ`, is required due to the way Mathlib handles
    sets.-/
theorem Sum'.of_univ {X:Type} {f:X → ℝ} (hf: AbsConvergent' f) :
  Sum' (fun x: (.univ : Set X) ↦ f x) = Sum' f := by
  have hsum_f : Summable f := (AbsConvergent'.iff_Summable f).mp hf
  have hsum_univ : Summable (λ x : (.univ : Set X) => f x) := hsum_f.comp_injective Subtype.val_injective
  have h_abs_conv_univ : AbsConvergent' (fun x : (.univ : Set X) ↦ f x) :=
    (AbsConvergent'.iff_Summable _).mpr hsum_univ
  calc
    Sum' (fun x : (.univ : Set X) ↦ f x) = ∑' x : (.univ : Set X), f x :=
      Sum'.eq_tsum _ h_abs_conv_univ
    _ = ∑' x : X, f x := by rw [tsum_univ]
    _ = Sum' f := by rw [Sum'.eq_tsum f hf]

theorem Sum'.of_comp {X Y:Type} {f:X → ℝ} (hf: AbsConvergent' f) {φ: Y → X}
  (hφ: Function.Bijective φ) :
  AbsConvergent' (f ∘ φ) ∧ Sum' f = Sum' (f ∘ φ) := by
  have hsum_f : Summable f := (AbsConvergent'.iff_Summable f).mp hf
  have hsum_f_comp : Summable (f ∘ φ) := hsum_f.comp_injective hφ.injective
  have h_abs_conv_comp : AbsConvergent' (f ∘ φ) :=
    (AbsConvergent'.iff_Summable _).mpr hsum_f_comp
  have h_sum' : Sum' f = Sum' (f ∘ φ) := by
    calc
      Sum' f = ∑' x, f x := Sum'.eq_tsum f hf
      _ = ∑' y, f (φ y) := ((Equiv.ofBijective φ hφ).tsum_eq f).symm
      _ = Sum' (f ∘ φ) := (Sum'.eq_tsum (f ∘ φ) h_abs_conv_comp).symm
  exact ⟨ h_abs_conv_comp, h_sum' ⟩

lemma AbsConvergent.summable_abs' {f : ℕ → ℝ} (h : AbsConvergent f) : Summable (|f|) := by
  rcases h with ⟨ g, hg, hconv ⟩
  have h_nonneg : (f ∘ g : Series).abs.nonneg := by
    intro n; dsimp [Series.nonneg, Series.abs, Series.mk']; split_ifs <;> simp
  choose g_inv hleft hright using bijective_iff_has_inverse.mp hg
  have h_bound (N : ℕ) : (f : Series).abs.partial (N : ℤ) ≤ (f ∘ g : Series).abs.sum := by
    let M := (Finset.range (N+1)).sup (λ n => g_inv n)
    have h_subset : (Finset.range (N+1)).image (λ n : ℕ => g_inv n) ⊆ Finset.range (M+1) := by
      intro k hk; simp at hk ⊢
      obtain ⟨ n, hn, rfl ⟩ := hk
      have hn_mem : n ∈ Finset.range (N+1) := Finset.mem_range.mpr (by
        have : n ≤ N := hn; omega)
      have : g_inv n ≤ M := Finset.le_sup (f := λ n : ℕ => g_inv n) hn_mem
      omega
    calc
      (f : Series).abs.partial (N : ℤ) = ∑ n ∈ Finset.range (N+1), |f n| := by
        rw [partial_abs_eq_range f N]
      _ = ∑ n ∈ Finset.range (N+1), |f (g (g_inv n))| := by
        refine Finset.sum_congr rfl fun n hn => ?_
        simp [hright n]
      _ = ∑ k ∈ (Finset.range (N+1)).image (λ n : ℕ => g_inv n), |f (g k)| := by
        have hinj_g_inv : Function.Injective (λ n : ℕ => g_inv n) := hright.injective
        have hinj : Set.InjOn (λ n : ℕ => g_inv n) (Finset.range (N+1) : Set ℕ) :=
          hinj_g_inv.injOn
        rw [Finset.sum_image hinj]
      _ ≤ ∑ k ∈ Finset.range (M+1), |f (g k)| := by
        have h_sdiff_nonneg : 0 ≤ ∑ k ∈ (Finset.range (M+1) \ ((Finset.range (N+1)).image (λ n : ℕ => g_inv n))), |f (g k)| :=
          Finset.sum_nonneg (λ _ _ => abs_nonneg _)
        have h_sum_sdiff := Finset.sum_sdiff h_subset (f := λ k : ℕ => |f (g k)|)
        linarith
      _ = (f ∘ g : Series).abs.partial (M : ℤ) := by
        simpa using (partial_abs_eq_range (f ∘ g) M).symm
      _ ≤ (f ∘ g : Series).abs.sum :=
        partial_le_sum_of_nonneg h_nonneg hconv (M : ℤ)
  have h_nonneg_abs : (f : Series).abs.nonneg := by
    intro n; dsimp [Series.nonneg, Series.abs, Series.mk']; split_ifs <;> simp
  have h_conv : (f : Series).abs.converges := by
    rw [converges_of_nonneg_iff h_nonneg_abs]
    use (f ∘ g : Series).abs.sum
    intro N; by_cases hN : N ≥ 0
    · lift N to ℕ using hN; apply h_bound N
    · have h_nonneg_sum : 0 ≤ (f ∘ g : Series).abs.sum :=
        Series.sum_of_nonneg h_nonneg
      have hN_lt : N < (f : Series).abs.m := by
        have hm : (f : Series).abs.m = 0 := rfl
        omega
      have h_partial_zero : (f : Series).abs.partial N = 0 :=
        Series.partial_of_lt hN_lt
      rw [h_partial_zero]
      exact h_nonneg_sum
  have h_summable_abs : Summable (|f|) := by
    rcases (converges_of_nonneg_iff h_nonneg_abs).mp h_conv with ⟨M, hM⟩
    have h_abs_conv' : AbsConvergent' f := by
      rw [AbsConvergent', bddAbove_def]
      use M
      intro y hy
      rcases hy with ⟨A, -, rfl⟩
      have h_subset : A ⊆ Finset.range (A.sup id + 1) := by
        intro x hx
        apply Finset.mem_range.mpr
        exact Nat.lt_succ_of_le (Finset.le_sup (f := id) hx)
      have h_sdiff_nonneg : 0 ≤ ∑ x ∈ (Finset.range (A.sup id + 1) \ A), |f x| :=
        Finset.sum_nonneg (λ x hx => abs_nonneg _)
      have h_sum_sdiff := Finset.sum_sdiff h_subset (f := λ x : ℕ => |f x|)
      have h_range_eq : ∑ x ∈ Finset.range (A.sup id + 1), |f x| = ((f : Series).abs).partial ((A.sup id : ℕ) : ℤ) := by
        rw [partial_abs_eq_range f (A.sup id)]
      have h_partial_le : ((f : Series).abs).partial ((A.sup id : ℕ) : ℤ) ≤ M := hM ((A.sup id : ℕ) : ℤ)
      calc
        ∑ x ∈ A, |f x| ≤ ∑ x ∈ Finset.range (A.sup id + 1), |f x| := by
          linarith
        _ = ((f : Series).abs).partial ((A.sup id : ℕ) : ℤ) := h_range_eq
        _ ≤ M := h_partial_le
    have h_summable_f : Summable f := (AbsConvergent'.iff_Summable f).mp h_abs_conv'
    exact summable_abs_iff.mpr h_summable_f
  exact h_summable_abs

/-- Lemma 8.2.7 / Exercise 8.2.4 -/
theorem divergent_parts_of_divergent {a: ℕ → ℝ} (ha: (a:Series).converges)
  (ha': ¬ (a:Series).absConverges) :
  ¬ AbsConvergent (fun n : {n | a n ≥ 0} ↦ a n) ∧ ¬ AbsConvergent (fun n : {n | a n < 0} ↦ a n)
  := by
  have ha_not_summable : ¬ Summable (|a|) := by
    intro h; apply ha'
    have h_nonneg_abs : ((a : Series).abs).nonneg := by
      intro n; dsimp [Series.nonneg, Series.abs, Series.mk']; split_ifs <;> simp
    have h_abs_conv : (a : Series).abs.converges := by
      rw [converges_of_nonneg_iff h_nonneg_abs]
      use ∑' n, |a n|
      intro N
      by_cases hN : N ≥ 0
      · lift N to ℕ using hN
        rw [partial_abs_eq_range a N]
        have hS : atTop.Tendsto (λ M : ℕ => ∑ x ∈ Finset.range M, |a x|) (nhds (∑' n, |a n|)) :=
          h.hasSum.tendsto_sum_nat
        have h_range_subset (m n : ℕ) (hmn : m ≤ n) : Finset.range m ⊆ Finset.range n := by
          intro x hx; rw [Finset.mem_range] at hx ⊢; omega
        have h_mono_range (m n : ℕ) (hmn : m ≤ n) : ∑ x ∈ Finset.range m, |a x| ≤ ∑ x ∈ Finset.range n, |a x| := by
          have h_sub : Finset.range m ⊆ Finset.range n := h_range_subset m n hmn
          have h_sdiff_nonneg : 0 ≤ ∑ x ∈ (Finset.range n \ Finset.range m), |a x| :=
            Finset.sum_nonneg (λ x hx => abs_nonneg _)
          have h_sum_sdiff := Finset.sum_sdiff h_sub (f := λ x : ℕ => |a x|)
          linarith
        have h_event : ∀ᶠ (M : ℕ) in atTop, ∑ x ∈ Finset.range (N+1), |a x| ≤ ∑ x ∈ Finset.range M, |a x| := by
          apply Filter.eventually_atTop.mpr
          refine ⟨N+1, λ M hM => h_mono_range (N+1) M hM⟩
        exact ge_of_tendsto hS h_event
      · have hN_lt : N < ((a : Series).abs).m := by
          have hm : ((a : Series).abs).m = 0 := rfl
          omega
        have h_partial : ((a : Series).abs).partial N = 0 :=
          Series.partial_of_lt hN_lt
        rw [h_partial]; exact tsum_nonneg (λ n => abs_nonneg _)
    simpa [absConverges] using h_abs_conv
  have h_pos : ¬ AbsConvergent (fun n : {n | a n ≥ 0} ↦ a n) := by
    intro h
    exfalso
    apply ha'
    rcases h with ⟨g, hg, hconv⟩
    let S : Set ℕ := {n | a n ≥ 0}
    let a_plus (n : ℕ) : ℝ := if a n ≥ 0 then a n else 0
    have ha_summable : Summable a := by
      have hL : (a : Series).convergesTo (a : Series).sum := Series.convergesTo_sum ha
      have hL' : HasSum a ((a : Series).sum) := by
        -- adapted from `hasSum_series_convergesTo` proof (Section_7_5.lean)
        rw [hasSum_iff_tendsto_nat]
        have h_of_range (N : ℕ) : (a : Series).partial (N : ℤ) = ∑ i ∈ Finset.range (N+1), a i := by
          unfold Series.partial
          simp [Series.eval_coe]
          have hIcc_eq : Finset.Icc (0 : ℤ) (N : ℤ) = (Finset.range (N+1)).image (fun (i : ℕ) => (i : ℤ)) := by
            ext x
            constructor
            · intro hx
              rcases Finset.mem_Icc.mp hx with ⟨hx1, hx2⟩
              have hx_lt : x.toNat < N+1 := by omega
              apply Finset.mem_image.mpr
              refine ⟨x.toNat, Finset.mem_range.mpr hx_lt, ?_⟩
              simp
            · intro hx
              rcases Finset.mem_image.mp hx with ⟨i, hi, rfl⟩
              rw [Finset.mem_range] at hi
              have hi_nonneg : (0 : ℤ) ≤ (i : ℤ) := by exact mod_cast Nat.zero_le i
              have hi_le_N : (i : ℤ) ≤ (N : ℤ) := by exact mod_cast hi
              exact Finset.mem_Icc.mpr ⟨hi_nonneg, hi_le_N⟩
          rw [hIcc_eq, Finset.sum_image]
          · simp
          · intro x hx y hy h; exact Nat.cast_inj.mp h
        have h_comp : Filter.Tendsto (fun (N : ℕ) => ∑ i ∈ Finset.range (N+1), a i) Filter.atTop (nhds ((a : Series).sum)) :=
          (hL.comp (by
            refine Filter.atTop_tendsto_atTop.mpr (λ z => ?_)
            refine ⟨max z 0, by intro n hn; omega⟩)).comp (tendsto_add_atTop_nat 1)
        simpa [Finset.sum_range_succ, h_of_range] using h_comp.comp (tendsto_add_atTop_nat 1)
      exact hL'.summable
    have ha_plus_summable : Summable a_plus := by
      by_cases hS_fin : Finite S
      · apply summable_of_finite_support
        refine Function.hasFiniteSupport.mpr ?_
        refine (Finset.filter (λ n => a n ≠ 0) (Finset.range (Nat.find (by
          -- pick an upper bound for all positive elements
          sorry)))).finite_toSet
        sorry
      · have hS_inf : Infinite S := by exact not_finite.mp hS_fin
        have h_CI : CountablyInfinite S := Nat.countable_of_infinite S
        have h_abs_conv_f : AbsConvergent' (fun x : S ↦ a x) := by
          have h_abs_conv : AbsConvergent (fun x : S ↦ a x) := .mk hg hconv
          rcases hS_fin with hS_fin | hS_inf
          · exact AbsConvergent'.of_finite _
          · exact ((AbsConvergent.iff h_CI (fun x : S ↦ a x)).mp h_abs_conv)
        rw [AbsConvergent'.iff_Summable] at h_abs_conv_f
        sorry
    sorry
  exact ⟨ h_pos, h_neg ⟩
        sorry
      have h_partial_bounded : ∃ C, 0 ≤ C ∧ ∀ N : ℤ, |(a : Series).partial N| ≤ C := by
        set S : Chapter6.Sequence := ⟨(a : Series).m, (a : Series).partial, by
          intro n hn; simp [Series.partial, hn]⟩
        have hS_conv : S.Convergent := by
          rw [Chapter6.Sequence.converges_iff_Tendsto']
          have h_convTo := Series.convergesTo_sum ha
          rcases ha with ⟨L, hL⟩
          use L
          simpa [S, Series.convergesTo] using hL
        have hS_bounded : S.IsBounded := S.bounded_of_convergent hS_conv
        rcases hS_bounded with ⟨C, hCpos, hC⟩
        exact ⟨C, hCpos, hC⟩
      rcases h_partial_bounded with ⟨C, hCpos, hC⟩
      have h_partial_eq_range (N : ℕ) : (a : Series).partial (N : ℤ) = ∑ k ∈ Finset.range (N+1), a k := by
        calc
          (a : Series).partial (N : ℤ) = ∑ n ∈ Finset.Icc (0 : ℤ) (N : ℤ), (a : Series).seq n := rfl
          _ = ∑ n ∈ Finset.Icc (0 : ℤ) (N : ℤ), a n.toNat := by
            refine Finset.sum_congr rfl (λ n hn => ?_)
            have hn0 : 0 ≤ n := (Finset.mem_Icc.mp hn).1
            simp [hn0, Series.eval_coe]
          _ = ∑ k ∈ Finset.range (N+1), a k := by
            have hIcc_eq : Finset.Icc (0 : ℤ) (N : ℤ) = (Finset.range (N+1)).image (fun (i : ℕ) => (i : ℤ)) := by
              ext x
              constructor
              · intro hx
                rcases Finset.mem_Icc.mp hx with ⟨hx1, hx2⟩
                have hx_lt : x.toNat < N+1 := by omega
                apply Finset.mem_image.mpr
                refine ⟨x.toNat, Finset.mem_range.mpr hx_lt, ?_⟩
                simp
              · intro hx
                rcases Finset.mem_image.mp hx with ⟨i, hi, rfl⟩
                rw [Finset.mem_range] at hi
                have hi_nonneg : (0 : ℤ) ≤ (i : ℤ) := by exact mod_cast Nat.zero_le i
                have hi_le_N : (i : ℤ) ≤ (N : ℤ) := by exact mod_cast (Nat.le_of_lt hi)
                exact Finset.mem_Icc.mpr ⟨hi_nonneg, hi_le_N⟩
            rw [hIcc_eq, Finset.sum_image]
            · simp
            · intro x hx y hy h; exact Nat.cast_inj.mp h
      have h_identity (N : ℕ) : (a : Series).abs.partial (N : ℤ) = 2 * (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) - (a : Series).partial (N : ℤ) := by
        have h_split : ∑ k ∈ Finset.range (N+1), |a k| = 
            (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) +
            (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), (-a k)) := by
          have h_disjoint : Disjoint (Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)))
              (Finset.filter (λ k => a k < 0) (Finset.range (N+1))) := by
            refine (Finset.disjoint_filter.mpr ?_)
            intro k hk hk_nonneg
            nlinarith
          have h_union : (Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1))) ∪
              (Finset.filter (λ k => a k < 0) (Finset.range (N+1))) = Finset.range (N+1) := by
            ext k; simp; omega
          calc
            ∑ k ∈ Finset.range (N+1), |a k| = ∑ k ∈ ((Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1))) ∪
                (Finset.filter (λ k => a k < 0) (Finset.range (N+1)))), |a k| := by rw [h_union]
            _ = (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), |a k|) +
                (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), |a k|) :=
              Finset.sum_union h_disjoint
            _ = (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) +
                (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), (-a k)) := by
              congrm ((∑ k, _) + (∑ k, _))
              · intro k hk; simp [(Finset.mem_filter.mp hk).2]
              · intro k hk; have hk_neg : a k < 0 := (Finset.mem_filter.mp hk).2; simp [hk_neg.le]
        calc
          (a : Series).abs.partial (N : ℤ) = ∑ k ∈ Finset.range (N+1), |a k| := by rw [partial_abs_eq_range a N]
          _ = (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) +
              (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), (-a k)) := h_split
          _ = (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) -
              (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), a k) := by simp [Finset.sum_neg_distrib]
          _ = 2 * (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) - 
              ((∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) + 
               (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), a k)) := by ring
          _ = 2 * (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) - (∑ k ∈ Finset.range (N+1), a k) := by
            have hQ_eq : Finset.filter (λ k => a k < 0) (Finset.range (N+1)) =
                Finset.filter (λ k => ¬ a k ≥ 0) (Finset.range (N+1)) := by
              ext k; simp; tauto
            rw [hQ_eq]
            rw [Finset.sum_filter_add_sum_filter_not (Finset.range (N+1)) (λ k => a k ≥ 0) (λ k => a k)]
          _ = 2 * (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) - (a : Series).partial (N : ℤ) := by rw [h_partial_eq_range N]
      use 2 * S_plus + C
      intro N
      by_cases hN : N ≥ 0
      · lift N to ℕ using hN
        rw [h_identity N]
        have h_pos_bound : (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) ≤ S_plus :=
          h_plus_bound N
        have h_neg_bound : - (a : Series).partial (N : ℤ) ≤ C := by
          have hN_abs := hC (N : ℤ)
          nlinarith
        nlinarith
      · have hN_lt : N < (a : Series).abs.m := by
          have hm : (a : Series).abs.m = 0 := rfl
          omega
        have h_zero : (a : Series).abs.partial N = 0 := Series.partial_of_lt hN_lt
        rw [h_zero]
        nlinarith
    exact h_abs_conv
  have h_neg : ¬ AbsConvergent (fun n : {n | a n < 0} ↦ a n) := by
    intro h
    exfalso
    apply ha'
    rcases h with ⟨g, hg, hconv⟩
    have h_abs_conv : (a : Series).absConverges := by
      have h_nonneg_abs : ((a : Series).abs).nonneg := by
        intro n; dsimp [Series.nonneg, Series.abs, Series.mk']; split_ifs <;> simp
      rw [Series.absConverges, Series.converges_of_nonneg_iff h_nonneg_abs]
      choose g_inv hleft hright using bijective_iff_has_inverse.mp hg
      let φ (k : ℕ) : ℕ := if h : a k < 0 then g_inv ⟨k, h⟩ else 0
      let S_minus := (a ∘ Subtype.val ∘ g : Series).abs.sum
      have h_nonneg_minus : ((a ∘ Subtype.val ∘ g : Series).abs).nonneg := by
        intro n; dsimp [Series.nonneg, Series.abs, Series.mk']; split_ifs <;> simp
      have hS_nonneg : 0 ≤ S_minus := Series.sum_of_nonneg h_nonneg_minus
      have h_partial_bound (N : ℤ) : ((a ∘ Subtype.val ∘ g : Series).abs).partial N ≤ S_minus :=
        Series.partial_le_sum_of_nonneg h_nonneg_minus hconv N
      have h_neg_bound (N : ℕ) : (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), -a k) ≤ S_minus := by
        let P := Finset.filter (λ k => a k < 0) (Finset.range (N+1))
        have hP_neg (k : ℕ) (hk : k ∈ P) : a k < 0 := (Finset.mem_filter.mp hk).2
        let K := P.sup φ
        have h_subset : P ⊆ Finset.image (Subtype.val ∘ g) (Finset.range (K+1)) := by
          intro k hk
          have hk_neg : a k < 0 := hP_neg k hk
          have h_φ_eq : φ k = g_inv ⟨k, hk_neg⟩ := by
            dsimp [φ]; rw [dif_pos hk_neg]
          have hk_bound : φ k ≤ K := Finset.le_sup (f := φ) hk
          have h_g_eq : Subtype.val (g (g_inv ⟨k, hk_neg⟩)) = k := by
            simpa using congrArg Subtype.val (hright ⟨k, hk_neg⟩)
          apply Finset.mem_image.mpr
          refine ⟨φ k, Finset.mem_range.mpr (by omega), ?_⟩
          dsimp [φ]; rw [dif_pos hk_neg]
          simpa using congrArg Subtype.val (hright ⟨k, hk_neg⟩)
        have h_inj : Function.Injective (Subtype.val ∘ g : ℕ → ℕ) :=
          Subtype.val_injective.comp hg.injective
        have h_nonneg_abs : ∀ x ∈ Finset.image (Subtype.val ∘ g) (Finset.range (K+1)), 0 ≤ |a x| := by
          intro x hx; apply abs_nonneg
        have h_sdiff_nonneg : 0 ≤ ∑ k ∈ (Finset.image (Subtype.val ∘ g) (Finset.range (K+1)) \ P), |a k| :=
          Finset.sum_nonneg (λ k hk => h_nonneg_abs k ((Finset.mem_sdiff.1 hk).1))
        have h_sum_sdiff := Finset.sum_sdiff h_subset (f := λ k : ℕ => |a k|)
        calc
          ∑ k ∈ P, (-a k) = ∑ k ∈ P, |a k| := by
            refine Finset.sum_congr rfl (λ k hk => ?_)
            have hk_neg : a k < 0 := hP_neg k hk
            simp [hk_neg.le]
          _ ≤ (∑ k ∈ P, |a k|) + (∑ k ∈ (Finset.image (Subtype.val ∘ g) (Finset.range (K+1)) \ P), |a k|) := by nlinarith
          _ = ∑ k ∈ Finset.image (Subtype.val ∘ g) (Finset.range (K+1)), |a k| := by linarith [h_sum_sdiff]
          _ = ∑ j ∈ Finset.range (K+1), |a (Subtype.val (g j))| :=
            Finset.sum_image (h_inj.injOn (s := (Finset.range (K+1) : Set ℕ)))
          _ = ((a ∘ Subtype.val ∘ g : Series).abs).partial (K : ℤ) := by
            rw [partial_abs_eq_range (a ∘ Subtype.val ∘ g) K]
          _ ≤ S_minus := h_partial_bound (K : ℤ)
      have h_partial_bounded : ∃ C, 0 ≤ C ∧ ∀ N : ℤ, |(a : Series).partial N| ≤ C := by
        set S : Chapter6.Sequence := ⟨(a : Series).m, (a : Series).partial, by
          intro n hn; simp [Series.partial, hn]⟩
        have hS_conv : S.Convergent := by
          rw [Chapter6.Sequence.converges_iff_Tendsto']
          have h_convTo := Series.convergesTo_sum ha
          rcases ha with ⟨L, hL⟩
          use L
          simpa [S, Series.convergesTo] using hL
        have hS_bounded : S.IsBounded := S.bounded_of_convergent hS_conv
        rcases hS_bounded with ⟨C, hCpos, hC⟩
        exact ⟨C, hCpos, hC⟩
      rcases h_partial_bounded with ⟨C, hCpos, hC⟩
      have h_partial_eq_range (N : ℕ) : (a : Series).partial (N : ℤ) = ∑ k ∈ Finset.range (N+1), a k := by
        calc
          (a : Series).partial (N : ℤ) = ∑ n ∈ Finset.Icc (0 : ℤ) (N : ℤ), (a : Series).seq n := rfl
          _ = ∑ n ∈ Finset.Icc (0 : ℤ) (N : ℤ), a n.toNat := by
            refine Finset.sum_congr rfl (λ n hn => ?_)
            have hn0 : 0 ≤ n := (Finset.mem_Icc.mp hn).1
            simp [hn0, Series.eval_coe]
          _ = ∑ k ∈ Finset.range (N+1), a k := by
            have hIcc_eq : Finset.Icc (0 : ℤ) (N : ℤ) = (Finset.range (N+1)).image (fun (i : ℕ) => (i : ℤ)) := by
              ext x
              constructor
              · intro hx
                rcases Finset.mem_Icc.mp hx with ⟨hx1, hx2⟩
                have hx_lt : x.toNat < N+1 := by omega
                apply Finset.mem_image.mpr
                refine ⟨x.toNat, Finset.mem_range.mpr hx_lt, ?_⟩
                simp
              · intro hx
                rcases Finset.mem_image.mp hx with ⟨i, hi, rfl⟩
                rw [Finset.mem_range] at hi
                have hi_nonneg : (0 : ℤ) ≤ (i : ℤ) := by exact mod_cast Nat.zero_le i
                have hi_le_N : (i : ℤ) ≤ (N : ℤ) := by exact mod_cast (Nat.le_of_lt hi)
                exact Finset.mem_Icc.mpr ⟨hi_nonneg, hi_le_N⟩
            rw [hIcc_eq, Finset.sum_image]
            · simp
            · intro x hx y hy h; exact Nat.cast_inj.mp h
      have h_identity (N : ℕ) : (a : Series).abs.partial (N : ℤ) = S_minus + (a : Series).partial (N : ℤ) := by
        calc
          (a : Series).abs.partial (N : ℤ) = ∑ k ∈ Finset.range (N+1), |a k| := by rw [partial_abs_eq_range a N]
          _ = (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) +
              (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), (-a k)) := by
            have h_disjoint : Disjoint (Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)))
                (Finset.filter (λ k => a k < 0) (Finset.range (N+1))) := by
              refine (Finset.disjoint_filter.mpr ?_)
              intro k hk hk_nonneg
              nlinarith
            have h_union : (Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1))) ∪
                (Finset.filter (λ k => a k < 0) (Finset.range (N+1))) = Finset.range (N+1) := by
              ext k; simp; omega
            calc
              ∑ k ∈ Finset.range (N+1), |a k| = ∑ k ∈ ((Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1))) ∪
                  (Finset.filter (λ k => a k < 0) (Finset.range (N+1)))), |a k| := by rw [h_union]
              _ = (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), |a k|) +
                  (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), |a k|) :=
                Finset.sum_union h_disjoint
              _ = (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) +
                  (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), (-a k)) := by
                congrm ((∑ k, ?_) + (∑ k, ?_))
                · intro k hk; simp [(Finset.mem_filter.mp hk).2]
                · intro k hk; have hk_neg : a k < 0 := (Finset.mem_filter.mp hk).2; simp [hk_neg.le]
          _ = S_minus + (a : Series).partial (N : ℤ) := by
            have h_range_sum : ∑ k ∈ Finset.range (N+1), a k = (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) +
                (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), a k) := by
              have h_disjoint' : Disjoint (Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)))
                  (Finset.filter (λ k => a k < 0) (Finset.range (N+1))) := by
                refine (Finset.disjoint_filter.mpr ?_)
                intro k hk hk_nonneg
                nlinarith
              have h_union' : (Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1))) ∪
                  (Finset.filter (λ k => a k < 0) (Finset.range (N+1))) = Finset.range (N+1) := by
                ext k; simp; omega
              calc
                ∑ k ∈ Finset.range (N+1), a k = ∑ k ∈ ((Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1))) ∪
                    (Finset.filter (λ k => a k < 0) (Finset.range (N+1)))), a k := by rw [h_union']
                _ = (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) +
                    (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), a k) :=
                  Finset.sum_union h_disjoint'
            have h_neg_sum : (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), a k) ≤ 0 := by
              refine Finset.sum_nonpos (λ k hk => ?_)
              have hk_neg : a k < 0 := (Finset.mem_filter.mp hk).2
              exact hk_neg.le
            have h_partial_eq : (a : Series).partial (N : ℤ) = ∑ k ∈ Finset.range (N+1), a k := h_partial_eq_range N
            nlinarith
      have h_sum_neg_bound (N : ℕ) : (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), (-a k)) ≤ S_minus :=
        h_neg_bound N
      have h_pos_abs_bound (N : ℕ) : (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) ≤
        (a : Series).partial (N : ℤ) + S_minus := by
        have h_range_sum : ∑ k ∈ Finset.range (N+1), a k = (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) +
            (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), a k) := by
          rw [Finset.sum_filter_add_sum_filter_not (Finset.range (N+1)) (λ k => a k ≥ 0) (λ k => a k)]
        have h_neg_sum : (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), a k) ≤ 0 := by
          refine Finset.sum_nonpos (λ k hk => ?_)
          have hk_neg : a k < 0 := (Finset.mem_filter.mp hk).2
          exact hk_neg.le
        have h_partial_eq : (a : Series).partial (N : ℤ) = ∑ k ∈ Finset.range (N+1), a k := h_partial_eq_range N
        nlinarith
      use C + S_minus
      intro N
      by_cases hN : N ≥ 0
      · lift N to ℕ using hN
        rw [h_identity N]
        have h_pos_part : (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) ≤ (a : Series).partial (N : ℤ) + S_minus :=
          h_pos_abs_bound N
        have h_neg_part : (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), (-a k)) ≤ S_minus :=
          h_sum_neg_bound N
        have h_partial_abs : |(a : Series).partial (N : ℤ)| ≤ C := hC (N : ℤ)
        have h_nonneg_sum_neg : 0 ≤ ∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), (-a k) :=
          Finset.sum_nonneg (λ k hk => by
            have hk_neg : a k < 0 := (Finset.mem_filter.mp hk).2
            nlinarith)
        calc
          (a : Series).abs.partial (N : ℤ) = (∑ k ∈ Finset.filter (λ k => a k ≥ 0) (Finset.range (N+1)), a k) +
              (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), (-a k)) := h_identity N
          _ ≤ ((a : Series).partial (N : ℤ) + S_minus) + (∑ k ∈ Finset.filter (λ k => a k < 0) (Finset.range (N+1)), (-a k)) := by
            nlinarith
          _ ≤ ((a : Series).partial (N : ℤ) + S_minus) + S_minus := by nlinarith
          _ = (a : Series).partial (N : ℤ) + 2 * S_minus := by ring
          _ ≤ |(a : Series).partial (N : ℤ)| + 2 * S_minus := by nlinarith
          _ ≤ C + 2 * S_minus := by nlinarith
      · have hN_lt : N < (a : Series).abs.m := by
          have hm : (a : Series).abs.m = 0 := rfl
          omega
        have h_zero : (a : Series).abs.partial N = 0 := Series.partial_of_lt hN_lt
        rw [h_zero]
        nlinarith
    exact h_abs_conv
  exact ⟨ h_pos, h_neg ⟩

/-- Theorem 8.2.8 (Riemann rearrangement theorem) / Exercise 8.2.5 -/
theorem permute_convergesTo_of_divergent {a: ℕ → ℝ} (ha: (a:Series).converges)
  (ha': ¬ (a:Series).absConverges) (L:ℝ) :
  ∃ f : ℕ → ℕ, Bijective f ∧ (a ∘ f:Series).convergesTo L
  := by
  sorry

/-- Exercise 8.2.6 -/
theorem permute_diverges_of_divergent {a: ℕ → ℝ} (ha: (a:Series).converges)
  (ha': ¬ (a:Series).absConverges)  :
  ∃ f : ℕ → ℕ,  Bijective f ∧ atTop.Tendsto (fun N ↦ ((a ∘ f:Series).partial N : EReal)) (nhds ⊤) := by
  sorry

theorem permute_diverges_of_divergent' {a: ℕ → ℝ} (ha: (a:Series).converges)
  (ha': ¬ (a:Series).absConverges)  :
  ∃ f : ℕ → ℕ,  Bijective f ∧ atTop.Tendsto (fun N ↦ ((a ∘ f:Series).partial N : EReal)) (nhds ⊥) := by
  sorry

end Chapter8
